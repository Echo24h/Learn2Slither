#!/usr/bin/env python3
"""Main entry point for the Learn2Slither Q-learning agent.

This script allows you to train and run a Q-learning agent that plays Snake.
Run with --help for available options.
"""
import argparse

from agent import QLearning
from config import Config


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Snake Q-learning agent",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )

    parser.add_argument(
        "-visual",
        choices=["on", "off"],
        default="on",
        help="Enable or disable game display (default: on)"
    )

    parser.add_argument(
        "-episodes",
        type=int,
        default=Config.EPISODES.value,
        help=f"Number of episodes to play (default: {Config.EPISODES.value})"
    )

    parser.add_argument(
        "-load",
        type=str,
        help="Path to a Q-table file to load"
    )

    parser.add_argument(
        "-save",
        type=str,
        help="Path to save the Q-table"
    )

    parser.add_argument(
        "-dontlearn",
        action="store_true",
        help="Disable learning during execution"
    )

    parser.add_argument(
        "-step-by-step",
        action="store_true",
        help="Wait for user input between each step"
    )

    args = parser.parse_args()

    # Convert arguments to appropriate types
    visual = args.visual == "on"
    learn = not args.dontlearn

    # Print configuration
    print("=" * 50)
    print("LEARN2SLITHER - Q-Learning Configuration")
    print("=" * 50)
    print(f"Visual:        {visual}")
    print(f"Episodes:      {args.episodes}")
    print(f"Load model:    {args.load or 'None'}")
    print(f"Save model:    {args.save or 'None'}")
    print(f"Learning:      {learn}")
    print(f"Step-by-step:  {args.step_by_step}")
    print("=" * 50)

    # Initialize and run the agent
    agent = QLearning(
        visual=visual,
        episodes=args.episodes,
        step_by_step=args.step_by_step,
        learn=learn
    )

    agent.load_model(args.load)
    agent.run()
    agent.save_model(args.save)
