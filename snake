#!/usr/bin/env python3
import sys
import argparse

from agent import QLearning
from config import Config


def help() -> None:
    """Display help message and exit."""
    print("-visual on/off : Display the game or not (default : on)")
    print("-sessions <int> : Number of games to play (default : 1)")
    print("-load <file> : Load a Q-table model")
    print("-save <file> : Save the Q-table model")
    print("-dontlearn : Disable learning")
    print("-step-by-step : Wait for user input between each step")
    print("-help : Display this message")
    print("Example:")
    print("./snake -visual on -load models/100sess.csvtxt -sessions 10")
    sys.exit(0)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Snake Q-learning agent")

    parser.add_argument(
        "-visual",
        choices=["on", "off"],
        default="on",
        help="Enable or disable game display (default: on)"
    )

    parser.add_argument(
        "-sessions",
        type=int,
        default=Config.EPISODES.value,
        help="Number of sessions to play"
    )

    parser.add_argument(
        "-load",
        type=str,
        help="Path to a Q-table file to load"
    )

    parser.add_argument(
        "-save",
        type=str,
        help="Path to save the Q-table"
    )

    parser.add_argument(
        "-dontlearn",
        action="store_true",
        help="Disable learning during execution"
    )

    parser.add_argument(
        "-step-by-step",
        action="store_true",
        help="Wait for user input between each step"
    )

    args = parser.parse_args()

    # Convert visual to boolean
    visual = args.visual == "on"
    learn = not args.dontlearn

    # Print configuration
    print("Visual:", visual)
    print("Sessions:", args.sessions)
    print("Load:", args.load)
    print("Save:", args.save)
    print("Learn:", learn)
    print("Step by step:", args.step_by_step)

    # Run the agent
    agent = QLearning(
        visual=visual,
        episodes=args.sessions,
        step_by_step=args.step_by_step,
        learn=learn
    )

    agent.load_model(args.load)
    agent.run()
    agent.save_model(args.save)
